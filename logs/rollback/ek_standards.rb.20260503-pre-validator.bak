  def required_docs_for(trigger)
    case trigger.to_sym
    when :compose_kitchen
      (ENTRYPOINT_DOCS + COMPOSE_DOCS + STANDARD_DOCS).uniq
    else
      ENTRYPOINT_DOCS
    end
  end

  def module_semantics(module_key)
    MODULE_SEMANTICS[module_key.to_s] || {}
  end

  def rule(id)
    RULES.find { |r| r[:id] == id.to_s }
  end

  def manifest(trigger: :compose_kitchen)
    docs = required_docs_for(trigger)
    {
      schema_version: VERSION,
      trigger: trigger.to_s,
      vault_root: VAULT_ROOT,
      library_root: LIBRARY_ROOT,
      library_alt: LIBRARY_ALT,
      appliance_paths: APPLIANCE_PATHS,
      required_docs: docs,
      rule_ids: RULES.map { |r| r[:id] },
      rules: RULES,
      module_semantics: MODULE_SEMANTICS,
    }
  end

  def appliance_path(kind, filename = nil)
    entry = APPLIANCE_PATHS[kind.to_sym]
    return nil unless entry
    return entry[:dir] unless filename
    File.join(entry[:dir], filename)
  end
end


