# Regeneratable (rebuild on demand)
mcp-gsc/venv/
node_modules/
db/node_modules/
plugins/cache/

# Session data (local only)
/projects/
file-history/
# Exception: skill project knowledge is tracked
!skills/**/projects/
debug/
todos/
plans/
shell-snapshots/
session-env/
history.jsonl

# Temp files
*.tmp
nul

# Secrets (never commit)
.credentials.json
.claude.json
credentials/*
!credentials/README.md
!credentials/_template.env
*.key
*.pem
token.json
client_secret*.json

# Backups (may contain sensitive data)
backups/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log

# Cache
cache/
statsig/
stats-cache.json

# Local Claude settings (IDE-specific permissions)
.claude/settings.local.json

# Database files (use schema-*.sql + migrate.js to recreate)
*.db
plugins/marketplaces/*/

# Ghost session data (local only)
.ai-sessions/
# Runtime/cache dirs (Claude Code managed)
sessions/
telemetry/
ide/
skills-workspace/
mcp-needs-auth-cache.json
# Runtime state (changes every session)
memory/session/capsule.json
hooks/pre-compact/.audit-state.json
hooks/maintenance/.last-decay
hooks/.distill-needed
hooks/maintenance/.last-decay
hooks/.distill-needed
scripts/.router-state.json
plugins/install-counts-cache.json
hooks/maintenance/.*-state.json
hooks/maintenance/.*.lock
hooks/stop/.*-state.json
hooks/.pending-report-*.txt
hooks/.checkpoint-*
hooks/.ghost-last-*
hooks/.auto-librarian-last-run.json
hooks/user-prompt-submit/.pre-task-loader-state.json
.last-cleanup

# Runtime caches (Claude Code managed)
image-cache/
paste-cache/
tasks/
tmp/
.claude/worktrees/

# Daily-rotated LLM telemetry (obsidian-api.js)
logs/llm-calls-*.jsonl

# Pattern data (runtime state, NOT code — code lives at db-helper.js / init-db.js / cleanup-db.js)
patterns/gemini-quota.json
patterns/usage-tracker.json
